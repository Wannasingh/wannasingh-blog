# Dockerfile for Node.js Express server using node-oracledb in Thin mode

FROM node:22-alpine

WORKDIR /app

# Install standard dependencies (excluding Vault CLI)
RUN apk add --no-cache bash ca-certificates

# Copy package descriptors and install production dependencies
COPY server/package*.json ./
RUN npm ci --only=production

# Copy backend source code
COPY server/ ./

# Expose backend port
EXPOSE 4001

# Start server directly
CMD ["node", "app.mjs"]
